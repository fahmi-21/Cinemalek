

@model IEnumerable<Cart>

<section class="h-100">
    <div class="container h-100 py-5">
        <div class="row d-flex justify-content-center align-items-center h-100">
            <div class="col-10">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-normal mb-0">Shopping Cart</h3>
                    <div>
                        <p class="mb-0">
                            <span class="text-muted">Sort by:</span> <a href="#!" class="text-body">
                                price <i class="fas fa-angle-down mt-1"></i>
                            </a>
                        </p>
                    </div>
                </div>


                @foreach (var item in Model)
                {
                    <div class="card rounded-3 mb-4">
                        <div class="card-body p-4">
                            <div class="row d-flex justify-content-between align-items-center">
                                <div class="col-md-2 col-lg-2 col-xl-2">
                                    <img src="~/Admin/Imgs/MoviesImg/@item.Movie.Img"
                                         class="img-fluid rounded-3">
                                </div>
                                <div class="col-md-3 col-lg-3 col-xl-3">
                                    <p class="lead fw-normal mb-2">@item.Movie.Name</p>
                                    <p><span class="text-muted">Size: </span>M <span class="text-muted">Description: </span>@item.Movie.Description</p>
                                </div>
                                <div class="col-md-3 col-lg-3 col-xl-2 d-flex">
                                    <a asp-area="Customer" asp-controller="Cart" asp-action="Decrement" asp-route-id="@item.Id" class="btn btn-link px-2">
                                        <i class="bi bi-dash-lg"></i>
                                    </a>

                                    <input id="form1" min="0" name="quantity" disabled value="@item.Count" type="number"
                                           class="form-control form-control-sm text-center" />

                                    <a asp-area="Customer" asp-controller="Cart" asp-action="Increment" asp-route-id="@item.Id" class="btn btn-link px-2">
                                        <i class="bi bi-plus-lg"></i>
                                    </a>
                                </div>
                                <div class="col-md-3 col-lg-2 col-xl-2 offset-lg-1">
                                    <h5 class="mb-0">@item.Movie.Price.ToString("c")</h5>
                                </div>
                                <div class="col-md-1 col-lg-1 col-xl-1 text-start">
                                    <a asp-area="Customer" asp-controller="Cart" asp-action="Delete" asp-route-id="@item.Id" class="text-danger">
                                        <i class="bi bi-trash-fill me-1"></i> Delete
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="card mb-4">
                    <div class="card-body p-4 d-flex flex-row">
                        <div data-mdb-input-init class="form-outline flex-fill">
                            <input type="text" id="form1" class="form-control form-control-lg" />
                            <label class="form-label" for="form1">Discound code</label>
                        </div>
                        <button type="button" data-mdb-button-init data-mdb-ripple-init class="btn btn-outline-warning btn-lg ms-3">Apply</button>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <button type="button" data-mdb-button-init data-mdb-ripple-init class="btn btn-warning btn-block btn-lg">Proceed to Pay</button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>