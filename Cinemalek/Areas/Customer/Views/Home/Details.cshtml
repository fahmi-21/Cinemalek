@model Cinemalek.ViewModels.MovieDetailsVM

@{
    ViewData["Title"] = "Movie Details";
}

<div class="container-fluid p-0" style="background-color:#f8f9fa; padding:50px 15px;">
    <div class="row g-0">

        <!-- صورة الفيلم -->
        <div class="col-md-5 d-flex align-items-start justify-content-center bg-dark">
            <img src="~/Admin/Imgs/MoviesImg/@Model.Movie.Img"
                 class="img-fluid rounded shadow-sm"
                 style="max-height:70vh; object-fit:cover;" />
        </div>

        <!-- تفاصيل الفيلم -->
        <div class="col-md-7 p-5 d-flex flex-column">
            <h1 class="text-primary mb-3">🎬 Movie Details</h1>

            <h5 class="text-muted">Movie Title</h5>
            <h2 class="fw-bold">@Model.Movie.Name</h2>

            <p class="text-muted">@Model.Movie.Description</p>

            <hr />

            <div class="row mb-2">
                <div class="col-6">
                    <strong>Category:</strong> @Model.Category?.Name ?? "N/A"
                </div>
                <div class="col-6">
                    <strong>Cinema:</strong> @Model.Cinema?.Location ?? "N/A"
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-6">
                    <strong>Date:</strong> @Model.Movie.Date.ToShortDateString()
                </div>
                <div class="col-6">
                    <strong>Status:</strong>
                    @if (Model.Movie.Status)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Not Available</span>
                    }
                </div>
            </div>

            <h4 class="text-primary mt-3">
                @Model.Movie.Price.ToString("c")
            </h4>

            <hr />

            <!-- Add To Cart Form -->
            <form asp-area="Customer" asp-controller="Cart" asp-action="AddToCart" method="post" class="mb-4">
                <input type="hidden" name="movieid" value="@Model.Movie.Id" />
                <div class="row align-items-center">
                    <div class="col-3">
                        <input type="number" name="count" value="1" min="1" class="form-control" />
                    </div>

                    <div class="col-9">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-cart4"></i> Add To Cart
                        </button>
                    </div>
                </div>
            </form>
            <div class="mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary w-50">
                    ← Back to Home
                </a>
            </div>
        </div>

    </div>
</div>